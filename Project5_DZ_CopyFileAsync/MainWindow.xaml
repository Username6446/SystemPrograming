<Window x:Class="Project5_DZ_CopyFileAsync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project5_DZ_CopyFileAsync"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Label DockPanel.Dock="Top" Padding="10" FontSize="30">From:</Label>
        <TextBox Margin ="10" Padding="5" DockPanel.Dock="Top" x:Name="fromTb"></TextBox>
        <Label DockPanel.Dock="Top" Padding="10" FontSize="30">To:</Label>
        <TextBox Margin ="10" Padding="5" DockPanel.Dock="Top" x:Name="toTb"></TextBox>
        <Button DockPanel.Dock="Top"></Button>
        <ProgressBar x:Name="progressBar"  
                     Height="20" 
                     DockPanel.Dock="Bottom"></ProgressBar>
        <Button DockPanel.Dock="Top" 
                Background="LightGreen"
                FontSize="50"
                FontWeight="Bold" 
                Click="Button_Click"
                >Copy File</Button>
    </DockPanel>
</Window>
